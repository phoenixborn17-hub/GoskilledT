// GoSkilled vNext — data model
// Principles: money in PAISE (Int); real FKs; double-entry ledger; idempotent webhooks;
// commissions ONLY on verified payment; PII encrypted at rest. See CLAUDE.md.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────── Identity ───────────────
enum Role {
  USER
  ADMIN
}

// goal-based onboarding (Blueprint §3 /onboarding)
enum UserGoal {
  SKILL
  INCOME
  BOTH
}

model User {
  id            String   @id @default(cuid())
  supabaseId    String?  @unique            // Supabase Auth user id
  phone         String?  @unique
  email         String?  @unique
  name          String?
  role          Role     @default(USER)
  referralCode  String   @unique
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  isVerified    Boolean  @default(false)
  goal          UserGoal?
  onboardedAt   DateTime?
  // DR-030 Day-0: one-time /welcome moment. Null = never seen; set on completion OR skip.
  welcomeSeenAt DateTime?
  // DR-030 Day-0: Get-Started checklist persistence (dismissal + seen-item ledger for analytics).
  // Derivable items (Lesson 0, preview, invites) are computed from real data — NEVER stored here.
  // Shape: { dismissedAt?: string(ISO); doneSeen?: string[] }. Zod-validated on read/write.
  checklistState Json?
  // GPS-M5 §2.4 notifications: hard email opt-out. Null/false = subscribed; true = opted out of ALL
  // product emails (even welcome / certificate-ready). Additive + nullable → non-breaking.
  emailOptOut   Boolean?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments   Enrollment[]
  lessonProgress LessonProgress[]
  certificates  Certificate[]
  quizAttempts  QuizAttempt[]
  orders        Order[]
  affiliate     Affiliate?
  ledgerAccount LedgerAccount?
  withdrawals   Withdrawal[]
  kyc           Kyc?
  uplineEdges   Referral[] @relation("Downline")
  downlineEdges Referral[] @relation("Upline")
  guruMessages  GuruMessage[]
  emailLogs     EmailLog[]
  contactVerifications ContactVerification[]
  affiliateLeads AffiliateLead[]
}

// ─────────────── Catalog / LMS ───────────────
enum CourseStatus {
  DRAFT
  PUBLISHED
  COMING_SOON
}

model Package {
  id            String   @id @default(cuid())
  slug          String   @unique            // skill-builder | career-booster
  name          String
  priceInPaise  Int                          // GST-INCLUSIVE display price (DR-023)
  gstRateBps    Int      @default(1800)     // 18% in basis points
  isActive      Boolean  @default(true)
  includesFutureCourses Boolean @default(false) // DR-021: true for Career Booster
  courses       PackageCourse[]
  orders        Order[]
}

model Course {
  id        String       @id @default(cuid())
  slug      String       @unique
  title     String
  summary   String?
  category  String?
  status    CourseStatus @default(DRAFT)
  order     Int          @default(0)
  modules   Module[]
  packages  PackageCourse[]
  enrollments Enrollment[]
  certificates Certificate[]
}

model PackageCourse {
  packageId String
  courseId  String
  package   Package @relation(fields: [packageId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])
  @@id([packageId, courseId])
}

model Module {
  id       String  @id @default(cuid())
  courseId String
  course   Course  @relation(fields: [courseId], references: [id])
  title    String
  order    Int     @default(0)
  lessons  Lesson[]
}

model Lesson {
  id            String  @id @default(cuid())
  moduleId      String
  module        Module  @relation(fields: [moduleId], references: [id])
  title         String
  videoAssetId  String?
  durationSec   Int     @default(0)
  order         Int     @default(0)
  isFreePreview Boolean @default(false)
  progress      LessonProgress[]
  knowledge     LessonKnowledge[]
  quiz          Quiz?
}

enum EnrollmentSource {
  PACKAGE
  DIRECT
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String
  courseId   String
  user       User             @relation(fields: [userId], references: [id])
  course     Course           @relation(fields: [courseId], references: [id])
  source     EnrollmentSource @default(PACKAGE)
  enrolledAt DateTime         @default(now())
  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  user        User     @relation(fields: [userId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  completedAt DateTime @default(now())
  @@unique([userId, lessonId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  user     User     @relation(fields: [userId], references: [id])
  course   Course   @relation(fields: [courseId], references: [id])
  serial   String   @unique
  issuedAt DateTime @default(now())
  @@unique([userId, courseId])
}

// ─────────────── Commerce / Payments ───────────────
enum OrderStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  packageId        String
  user             User        @relation(fields: [userId], references: [id])
  package          Package     @relation(fields: [packageId], references: [id])
  amountInPaise    Int
  gstInPaise       Int         @default(0)
  chosenCourseId   String?                  // DR-021: Skill Builder buyer's course choice
  status           OrderStatus @default(CREATED)
  razorpayOrderId  String?     @unique
  razorpayPaymentId String?    @unique
  createdAt        DateTime    @default(now())
  paidAt           DateTime?
}

// Idempotency ledger for provider webhooks — the anti-double-credit guard.
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String                        // "razorpay"
  eventId     String                        // provider event id
  payloadHash String
  processedAt DateTime @default(now())
  @@unique([provider, eventId])
}

// ─────────────── Affiliate ───────────────
// REGISTERED = free signup; ACTIVE = purchased & credited
enum ReferralStatus {
  REGISTERED
  ACTIVE
}

enum AffiliateStatus {
  ACTIVE
  SUSPENDED
}

model Affiliate {
  id        String          @id @default(cuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id])
  status    AffiliateStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
}

model Referral {
  id             String         @id @default(cuid())
  uplineUserId   String
  downlineUserId String
  upline         User           @relation("Upline", fields: [uplineUserId], references: [id])
  downline       User           @relation("Downline", fields: [downlineUserId], references: [id])
  level          Int                                   // 1 | 2 | 3
  packageId      String?
  status         ReferralStatus @default(REGISTERED)
  commissionInPaise Int         @default(0)
  activatedAt    DateTime?
  createdAt      DateTime       @default(now())
  @@unique([uplineUserId, downlineUserId, level])
  @@index([downlineUserId])
}

// ─────────────── Double-entry Ledger ───────────────
enum AccountType {
  USER_WALLET
  REVENUE
  COMMISSION_PAYABLE
  PAYOUT_CLEARING
  GST_PAYABLE
}

model LedgerAccount {
  id      String      @id @default(cuid())
  type    AccountType
  userId  String?     @unique               // null for system accounts
  user    User?       @relation(fields: [userId], references: [id])
  entries LedgerEntry[]
  // Balance is DERIVED = sum(entries.amountInPaise). Never stored as a mutable column.
}

// A LedgerTransaction groups >=2 entries whose signed amounts sum to ZERO.
// CLAWBACK = within-window refund reversal (DR-025). ADJUSTMENT = post-window manual
// refund — negative entry nets against FUTURE earnings; never reclaim paid-out money.
enum LedgerTxType {
  COMMISSION
  PAYOUT
  ADJUSTMENT
  CLAWBACK
}

model LedgerTransaction {
  id             String       @id @default(cuid())
  type           LedgerTxType
  idempotencyKey String   @unique              // "commission:{orderId}:{uplineId}:{level}" | "clawback:{orderId}:{uplineId}:{level}"
  refType        String?
  refId          String?
  createdAt      DateTime @default(now())
  entries        LedgerEntry[]
}

model LedgerEntry {
  id            String   @id @default(cuid())
  transactionId String
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  accountId     String
  account       LedgerAccount     @relation(fields: [accountId], references: [id])
  amountInPaise Int                            // signed: +credit / -debit
  holdUntil     DateTime?                      // DR-025: commission credits are HELD until refund window closes.
                                               // AVAILABLE balance = entries where holdUntil is null OR holdUntil <= now.
                                               // UI must show Held vs Available separately (held = visible, not withdrawable).
  createdAt     DateTime @default(now())
  @@index([accountId])
}

enum WithdrawalStatus {
  APPLIED
  IN_PROGRESS
  PAID
  REJECTED
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  amountInPaise Int
  status        WithdrawalStatus @default(APPLIED)
  adminNote     String?
  requestedAt   DateTime         @default(now())
  paidAt        DateTime?
  // Single-pending enforced in logic + partial unique index (see migration).
}

// ─────────────── KYC (PII encrypted at rest) ───────────────
enum KycStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Kyc {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  panEnc           String?                     // AES-256-GCM ciphertext
  accountHolderEnc String?                     // account-holder name, encrypted (LC #32; was bankNameEnc)
  accountNoEnc     String?
  ifsc          String?
  upi           String?
  whatsapp      String?
  status        KycStatus @default(DRAFT)
  submittedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  // Phase C (DR-037) additive expansion — all nullable, non-breaking.
  email             String?               // contact email (verify flag below)
  emailVerifiedAt   DateTime?             // set ONLY on a confirmed email verification
  whatsappVerifiedAt DateTime?            // set ONLY on a confirmed WhatsApp verification
  bankName          String?               // plaintext — not secret PII
  docType           String?               // address-proof document type (LAUNCH_CONFIG option list)
  // Private-bucket object paths, AES-256-GCM encrypted (Phase C §3 "any doc references → encrypted").
  addressDocEnc     String?
  panDocEnc         String?
  bankDocEnc        String?
}

// Email / WhatsApp verification codes (Phase C §3). The SEND provider is LAUNCH_CONFIG (Layer-2);
// this table backs the flow. Only a hash of the code is stored; the flag on Kyc is set on confirm.
model ContactVerification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  channel    String                        // "email" | "whatsapp"
  target     String                        // the email / number being verified
  codeHash   String                        // sha-256 of the 6-digit code (never the raw code)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  @@index([userId, channel])
}

// ─────────────── CRM / Marketing ───────────────
enum LeadStage {
  NEW
  CONTACTED
  WEBINAR_REGISTERED
  CONVERTED
  LOST
}

model Lead {
  id              String    @id @default(cuid())
  name            String?
  phone           String?
  email           String?
  source          String?
  utmSource       String?                     // KB-10 lead-handoff contract (Blueprint §5)
  utmMedium       String?
  utmCampaign     String?
  stage           LeadStage @default(NEW)
  packageInterest String?
  createdAt       DateTime  @default(now())
  @@unique([phone, source])                   // dedup: same phone from same source = one lead
  @@index([stage])
}

model Webinar {
  id        String   @id @default(cuid())
  title     String
  startsAt  DateTime
  joinUrl   String?
  isActive  Boolean  @default(true)
}

// ─────────────── Admin audit ───────────────
// DR-024: ONE auth authority — Supabase Auth for users AND admins (role claim + RBAC).
// No OtpCode table (Supabase owns OTP), no AdminUser/passwordHash (no hand-rolled auth).
model AdminAction {
  id             String   @id @default(cuid())
  actorSupabaseId String                       // Supabase Auth user id of the admin
  actorEmail     String?                       // denormalized for readable audit trails
  action         String
  entity         String
  entityId       String?
  meta           Json?
  createdAt      DateTime @default(now())
  @@index([actorSupabaseId])
}

// ─────────────── AI / Guru (GPS-M5 §2.0) ───────────────
// Course Knowledge Base: corpus Guru answers FROM (never general LLM knowledge). Transcript is the
// primary source; NOTES/GLOSSARY enrich when a founder provides them. One row per (lesson, kind);
// chunking + retrieval happen in code (modules/ai/guru/retrieval.ts) — simplest-that-works.
enum KnowledgeKind {
  TRANSCRIPT
  NOTES
  GLOSSARY
}

model LessonKnowledge {
  id        String        @id @default(cuid())
  lessonId  String
  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  kind      KnowledgeKind @default(TRANSCRIPT)
  content   String                              // raw text; placeholder-labeled until real recordings (LC #7/8)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@unique([lessonId, kind])
}

// Every Guru turn's usage/cost log (cost caps are architecture). Content is course Q&A, not PII —
// still excluded from the analytics corpus. Indexed for the per-user daily cap + global daily budget.
enum GuruVerdict {
  ANSWERED    // cited answer from corpus
  REDIRECTED  // out-of-scope → warm redirect to course content
  BLOCKED     // D-29 guardrail (income/earnings) → warm refusal
  CAPPED      // per-user or global cap hit → honest "thak gaya" state
  EMPTY       // lesson has no knowledge yet → honest "abhi sikhaya nahi" state
  ERROR       // provider failure → warm retry state
}

model GuruMessage {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  courseId         String?                              // derived from lesson; used for scoping/accounting
  lessonId         String?
  question         String
  answer           String
  verdict          GuruVerdict
  citations        Json?                                // [{ lessonId, title }]
  promptTokens     Int         @default(0)
  completionTokens Int         @default(0)
  costPaise        Int         @default(0)              // money in paise (Golden Rule 1)
  createdAt        DateTime    @default(now())
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─────────────── Quizzes (GPS-M5 §2.2) ───────────────
// Admin-drafted → published (Art 6: agents draft, humans decide). One checkpoint per lesson. A quiz
// marked isMandatory + PUBLISHED extends the course certificate gate (isEligibleForCertificate) —
// existing courses (no mandatory quizzes) keep their exact prior eligibility outcome.
enum QuizStatus {
  DRAFT
  PUBLISHED
}

model Quiz {
  id          String         @id @default(cuid())
  lessonId    String         @unique                    // one checkpoint per lesson
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  status      QuizStatus     @default(DRAFT)
  isMandatory Boolean        @default(false)            // counts toward the course certificate gate
  passPercent Int            @default(70)               // pass threshold (LC #38)
  // GPS-M5 §2.2 grandfather rule: a mandatory quiz gates ONLY course-completions at/after this moment.
  // Set when published, cleared when unpublished. Learners who finished before it existed are exempt.
  publishedAt DateTime?
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model QuizQuestion {
  id           String  @id @default(cuid())
  quizId       String
  quiz         Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt       String
  options      Json                                     // string[] (2–6 options)
  correctIndex Int                                      // index into options
  explanation  String?                                  // warm "Sahi! Kyunki…" feedback
  order        Int     @default(0)
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  score     Int                                         // correct count
  total     Int
  passed    Boolean
  answers   Json                                        // number[] selected indices
  createdAt DateTime @default(now())
  @@index([userId, quizId])
  @@index([quizId])
}

// ─────────────── Notifications (GPS-M5 §2.4) ───────────────
// Idempotent email send-log: a unique dedupeKey (e.g. "welcome:{userId}", "cert-ready:{serial}")
// makes every send at-most-once — the row is CLAIMED before the send, so a double-send is impossible.
// No PII stored (dedupeKey + internal userId + kind only).
model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dedupeKey String   @unique
  kind      String                                       // "welcome" | "certificate_ready"
  sentAt    DateTime @default(now())
  @@index([userId])
}

// ─────────────── Phase D — Rewards / Tiers (DR-034/DR-035) ───────────────
// Admin-configurable reward definitions. `metric` names what `target` measures (default:
// completed-referrals — learning-first, NEVER earnings/team-size, DR-035). Per-affiliate progress
// is DERIVED from canon (no stored progress column → never stale, never fabricated).
model RewardDefinition {
  id          String    @id @default(cuid())
  title       String
  description String?
  metric      String    @default("completed_referrals") // what `target` counts
  target      Int                                        // e.g. 10 completed referrals
  lastDate    DateTime?                                  // optional deadline
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────────── Phase D — My-Leads (affiliate-uploaded, owner-scoped, PII) ───────────────
// Distinct from the CRM `Lead` (public funnel). These are leads an AFFILIATE uploads for their own
// follow-up. Phone/email are PII → AES-256-GCM encrypted at rest (lib/pii), masked on display,
// owner-scoped access, never logged. (Flagged for Fable — PII policy.)
enum AffiliateLeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

model AffiliateLead {
  id        String              @id @default(cuid())
  ownerId   String                                        // the affiliate who uploaded this lead
  owner     User                @relation(fields: [ownerId], references: [id])
  name      String?
  phoneEnc  String                                        // AES-256-GCM ciphertext (PII)
  emailEnc  String?                                       // optional PII, encrypted
  note      String?
  status    AffiliateLeadStatus @default(NEW)
  createdAt DateTime            @default(now())
  @@index([ownerId, createdAt])
}
