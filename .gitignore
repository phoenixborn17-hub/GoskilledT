# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ── Environment & secrets (NEVER commit) ──────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.crt
secrets.*

# ── Next.js / build artifacts ─────────────────────────────────
.next/
out/
build/
dist/
.vercel

# ── Prisma generated client (regenerated via `prisma generate`) ─
/lib/generated

# ── TypeScript build info ─────────────────────────────────────
*.tsbuildinfo
# next-env.d.ts is auto-generated per-environment by `next dev`/`next build` and references
# ./.next/types (which is git-ignored), so it is git-ignored per Next.js convention (Ticket 3 finding).
next-env.d.ts

# ── Tests / coverage ──────────────────────────────────────────
/coverage
/playwright-report
/test-results
/blob-report
/playwright/.cache

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Local databases ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# ── IDE / editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code local machine settings ────────────────────────
.claude/settings.local.json
