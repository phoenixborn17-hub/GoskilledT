# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""      # server only — never expose

# --- Provider adapters (Ticket 3) — switching to prod = change values + add credentials ---
PAYMENT_PROVIDER="mock"           # mock | razorpay   (mock = dev only; FORBIDDEN in production)
OTP_PROVIDER="test"               # test | live       (test = Supabase test numbers; FORBIDDEN in production)
DEV_TEST_PHONES=""                # optional: comma-separated 10-digit Supabase test numbers (dev allowlist)

# --- Razorpay ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""            # server only
RAZORPAY_WEBHOOK_SECRET=""        # verify webhook signatures; also used by scripts/dev-simulate-webhook.ts in mock mode

# --- SMS OTP (MSG91) ---
MSG91_AUTH_KEY=""

# --- PII encryption (KYC) ---
PII_ENCRYPTION_KEY=""             # 32-byte base64 key for AES-256-GCM

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
