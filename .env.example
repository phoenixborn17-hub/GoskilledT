# --- Database (Supabase Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""      # server only — never expose

# --- Provider adapters (Tickets 3–4) — switching to prod = change values + add credentials ---
PAYMENT_PROVIDER="mock"           # mock | razorpay   (mock = dev only; FORBIDDEN in production)
OTP_PROVIDER="test"               # test | live       (test = Supabase test numbers; FORBIDDEN in production)
VIDEO_PROVIDER="mock"             # mock | stream     (mock = sample MP4s; FORBIDDEN in production)
ANALYTICS_PROVIDER="console"      # console | posthog (console = JSON logs; ALLOWED in prod but soft-warns — off ≠ unsafe)
EMAIL_PROVIDER="console"          # console | resend  (console = logged, not sent; ALLOWED in prod but soft-warns)
AI_PROVIDER="mock"                # mock | live       (mock = canned Guru answers, dev/tests; ALLOWED in prod but soft-warns — GPS-M5)
DEV_TEST_PHONES=""                # optional: comma-separated 10-digit Supabase test numbers (dev allowlist)

# --- Guru AI tutor (GPS-M5 §2.0) — only ANTHROPIC_API_KEY needed when AI_PROVIDER=live ---
ANTHROPIC_API_KEY=""              # server only (LC #35)
GURU_MODEL=""                     # optional override; default claude-haiku-4-5 (founder cost decision, LC #36)
GURU_DAILY_MSG_CAP=""             # optional; default 30 per user/day  (cost cap, LC #36)
GURU_DAILY_TOKEN_BUDGET=""        # optional; default 2000000 tokens/day global  (cost cap, LC #36)

# --- Email (Resend) — only needed when EMAIL_PROVIDER=resend ---
RESEND_API_KEY=""                 # server only
EMAIL_FROM="GoSkilled <noreply@goskilled.in>"   # verified sender for Resend
# HMAC key for signed unsubscribe links. REQUIRED in production (boot fails without it). In dev it
# derives from DATABASE_URL if unset, so a laptop boots without extra config.
EMAIL_UNSUBSCRIBE_SECRET=""       # server only — set a strong random value in prod

# --- Cloudflare Stream (DR-022) — only needed when VIDEO_PROVIDER=stream ---
CLOUDFLARE_STREAM_CUSTOMER_CODE=""

# --- Razorpay ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""            # server only
RAZORPAY_WEBHOOK_SECRET=""        # verify webhook signatures; also used by scripts/dev-simulate-webhook.ts in mock mode

# --- Analytics (Ticket 8) — only needed when ANALYTICS_PROVIDER=posthog (server-side only) ---
POSTHOG_API_KEY=""                # PostHog project API key
POSTHOG_HOST=""                   # optional; defaults to https://us.i.posthog.com

# --- SMS OTP (MSG91) ---
MSG91_AUTH_KEY=""

# --- PII encryption (KYC) ---
PII_ENCRYPTION_KEY=""             # 32-byte base64 key for AES-256-GCM

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Deployment mode: development | staging | production. Only "staging" carries behaviour.
# On test.goskilled.in it lets a PRODUCTION build (NODE_ENV=production) boot with mock
# payment/OTP/video so the whole app runs end-to-end with NO real money/SMS/video — the guard
# warns loudly instead of throwing, and an app-wide STAGING banner shows. HARD RULE: APP_ENV=staging
# on the prod domain (goskilled.in / www.goskilled.in) STILL hard-throws — you can never simulate
# money on production. Leave unset in dev and real prod (unset = today's strict behaviour).
APP_ENV=""                        # ""|development|staging|production  (set "staging" ONLY on test.goskilled.in)
# Staging OTP bypass code. ONLY active when APP_ENV=staging on a non-prod host (isStagingMode()).
# In staging, no SMS is sent and this fixed code is accepted for ANY phone so testers can
# register/login/checkout; the app then get-or-creates the phone user + mints a real session via the
# service_role Admin API. UNREACHABLE in real production and on the prod domain. Staging MUST use a
# NON-production Supabase project (this writes auth users). Default 123456 if unset.
STAGING_OTP_CODE=""               # e.g. "123456" — staging only

# --- Legal gates (Decision Register) ---
AFFILIATE_PAYOUTS_ENABLED="false"  # D-01: affiliate payouts stay OFF until legal sign-off. Read by lib/env.ts payoutsEnabled().
D01_LEGAL_CLEARED="false"          # LC #1: set true ONLY after counsel clears D-01. Gates the /admin/settings payout-flag ceremony (lib/config/launch.ts).

# --- QA-01 screenshot harness (scripts/qa-auth-bootstrap.ts) ---
# The bootstrap mints a QA admin via SQL, so it refuses any non-localhost Supabase project unless you
# acknowledge it is dev/staging. Set to "1" for a remote staging project. It can NEVER override a
# PRODUCTION_SUPABASE_URL match — that is hard-blocked regardless.
QA_BOOTSTRAP_ALLOW=""              # "1" to allow qa-auth-bootstrap against a remote (non-localhost) staging project
PRODUCTION_SUPABASE_URL=""         # optional: pin the prod project URL so the QA bootstrap hard-blocks it
