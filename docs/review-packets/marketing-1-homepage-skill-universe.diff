   stroke-dashoffset: 0;
   animation: none;
 }
+
+/* ── ⭐ Living Skill Universe (Public Experience hero signature moment) ──────────────────────────
+      Centre = You; real skill nodes orbit with animated SVG connectors. No WebGL. All motion is
+      transform/opacity only (60fps, CLS 0), reduced-motion-gated, and killed on low device-tier —
+      the static network stays fully legible + meaningful. Nodes are real <button>s (WCAG AA). ── */
+.su-wrap {
+  width: 100%;
+}
+.su-canvas {
+  position: relative;
+  width: 100%;
+  max-width: 30rem;
+  margin-inline: auto;
+  aspect-ratio: 1 / 1;
+  isolation: isolate;
+}
+@media (min-width: 640px) {
+  .su-canvas {
+    max-width: 34rem;
+  }
+}
+
+/* Connectors — crisp under the stretched viewBox via non-scaling-stroke. */
+.su-links {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  z-index: 0;
+  pointer-events: none;
+  overflow: visible;
+}
+.su-link {
+  stroke: rgb(19 126 73 / 0.18);
+  stroke-width: 1.5;
+  transition:
+    stroke 200ms ease,
+    stroke-width 200ms ease;
+}
+.su-link-on {
+  stroke: rgb(19 126 73 / 0.55);
+  stroke-width: 2.5;
+}
+/* Energy pulse: a brighter overlay line breathing You → skill (semantic: connection is alive). */
+.su-pulse {
+  stroke: rgb(26 160 94 / 0.5);
+  stroke-width: 2;
+  opacity: 0;
+}
+@media (prefers-reduced-motion: no-preference) {
+  .su-pulse {
+    animation: su-pulse 3.6s ease-in-out infinite;
+  }
+  @keyframes su-pulse {
+    0%,
+    100% {
+      opacity: 0;
+    }
+    45% {
+      opacity: 0.6;
+    }
+  }
+}
+
+/* Centre — You (green fill + gold ring, echoing the brand monogram). */
+.su-center {
+  position: absolute;
+  left: 50%;
+  top: 50%;
+  transform: translate(-50%, -50%);
+  z-index: 2;
+  display: grid;
+  place-items: center;
+  gap: 0.375rem;
+}
+.su-center-ring {
+  position: relative;
+  display: grid;
+  place-items: center;
+  height: 4.25rem;
+  width: 4.25rem;
+  border-radius: 9999px;
+  color: #fff;
+  background: linear-gradient(135deg, var(--gs-green-deep), var(--gs-green));
+  box-shadow:
+    0 0 0 3px rgb(237 200 37 / 0.7),
+    0 8px 24px -6px rgb(19 126 73 / 0.5);
+}
+.su-center-ring::after {
+  content: "";
+  position: absolute;
+  inset: -0.5rem;
+  border-radius: 9999px;
+  border: 1px solid rgb(19 126 73 / 0.18);
+}
+@media (prefers-reduced-motion: no-preference) {
+  .su-center-ring::after {
+    animation: su-breathe 3.2s ease-in-out infinite;
+  }
+  @keyframes su-breathe {
+    0%,
+    100% {
+      transform: scale(1);
+      opacity: 0.5;
+    }
+    50% {
+      transform: scale(1.12);
+      opacity: 0.9;
+    }
+  }
+}
+.su-center-label {
+  font-family: var(--font-heading);
+  font-size: 0.8125rem;
+  font-weight: 700;
+  color: var(--gs-green-deep);
+  background: rgb(254 254 254 / 0.85);
+  padding: 0.05rem 0.5rem;
+  border-radius: 9999px;
+}
+
+/* Skill node — the button anchors its BADGE centre exactly on the connector endpoint; the label +
+   status sit absolutely below so the badge stays pinned (line always meets the circle). */
+.su-node {
+  position: absolute;
+  transform: translate(-50%, -50%);
+  z-index: 1;
+  display: grid;
+  place-items: center;
+  background: transparent;
+  border: 0;
+  cursor: pointer;
+  padding: 0;
+}
+.su-node-badge {
+  display: grid;
+  place-items: center;
+  height: 3.25rem;
+  width: 3.25rem;
+  border-radius: 9999px;
+  background: var(--gs-surface-raised);
+  transition:
+    transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
+    box-shadow 200ms ease,
+    border-color 200ms ease;
+}
+.su-node-live {
+  border: 2px solid var(--gs-green-600);
+  color: var(--gs-green-700);
+  box-shadow:
+    0 2px 10px -2px rgb(19 126 73 / 0.35),
+    inset 0 1px 0 rgb(255 255 255 / 0.6);
+}
+.su-node-soon {
+  border: 1.5px solid var(--gs-n-200);
+  color: var(--gs-n-500);
+  box-shadow: var(--gs-shadow-sm);
+}
+.su-node-label {
+  position: absolute;
+  top: calc(100% + 0.375rem);
+  left: 50%;
+  transform: translateX(-50%);
+  white-space: nowrap;
+  font-family: var(--font-heading);
+  font-size: 0.8125rem;
+  font-weight: 700;
+  color: var(--gs-charcoal);
+}
+.su-node-status {
+  position: absolute;
+  top: calc(100% + 1.55rem);
+  left: 50%;
+  transform: translateX(-50%);
+  font-size: 0.625rem;
+  font-weight: 700;
+  letter-spacing: 0.02em;
+  text-transform: uppercase;
+}
+.su-status-live {
+  color: var(--gs-green-700);
+}
+.su-status-soon {
+  color: var(--gs-muted);
+}
+/* Hover/focus/active — lift + strengthen (capable tier; flattened on low tier below). */
+@media (prefers-reduced-motion: no-preference) {
+  .su-node:hover .su-node-badge,
+  .su-node:focus-visible .su-node-badge,
+  .su-node-on .su-node-badge {
+    transform: translateY(-3px) scale(1.06);
+  }
+}
+.su-node:hover .su-node-live,
+.su-node-on .su-node-live {
+  box-shadow:
+    0 10px 26px -6px rgb(19 126 73 / 0.5),
+    inset 0 1px 0 rgb(255 255 255 / 0.6);
+}
+.su-node:hover .su-node-soon,
+.su-node-on .su-node-soon {
+  border-color: var(--gs-n-300);
+  color: var(--gs-n-700);
+}
+.su-node:focus-visible {
+  outline: none;
+}
+.su-node:focus-visible .su-node-badge {
+  outline: 2px solid var(--gs-green-600);
+  outline-offset: 3px;
+}
+
+/* Reveal panel — honest detail for the active node; a calm brand line at rest. */
+.su-reveal {
+  margin-top: 1rem;
+  min-height: 6.5rem;
+}
+.su-reveal-rest {
+  text-align: center;
+  font-size: 0.9375rem;
+  color: var(--gs-charcoal);
+  max-width: 22rem;
+  margin-inline: auto;
+}
+.su-reveal-card {
+  max-width: 24rem;
+  margin-inline: auto;
+  border: 1px solid var(--gs-border);
+  border-radius: var(--gs-radius-lg);
+  background: var(--gs-surface-raised);
+  box-shadow: var(--gs-shadow);
+  padding: 1rem 1.125rem;
+}
+@media (prefers-reduced-motion: no-preference) {
+  .su-reveal-card {
+    animation: enter-up 260ms cubic-bezier(0.16, 1, 0.3, 1) both;
+  }
+}
+.su-reveal-head {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 0.75rem;
+}
+.su-reveal-title {
+  font-family: var(--font-heading);
+  font-size: 1.0625rem;
+  font-weight: 700;
+  color: var(--gs-charcoal);
+}
+.su-reveal-chip {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.375rem;
+  font-size: 0.6875rem;
+  font-weight: 700;
+  padding: 0.125rem 0.5rem;
+  border-radius: 9999px;
+  white-space: nowrap;
+}
+.su-chip-dot {
+  height: 0.375rem;
+  width: 0.375rem;
+  border-radius: 9999px;
+  background: currentColor;
+}
+.su-chip-live {
+  color: var(--gs-green-700);
+  background: var(--gs-green-50);
+}
+.su-chip-soon {
+  color: var(--gs-warning-strong);
+  background: var(--gs-gold-50);
+}
+.su-reveal-blurb {
+  margin-top: 0.5rem;
+  font-size: 0.875rem;
+  line-height: 1.5;
+  color: var(--gs-muted);
+}
+.su-reveal-link {
+  margin-top: 0.75rem;
+  display: inline-flex;
+  align-items: center;
+  gap: 0.375rem;
+  font-size: 0.875rem;
+  font-weight: 600;
+  color: var(--gs-green-700);
+}
+.su-reveal-link:hover {
+  color: var(--gs-green-800);
+}
+
+/* Low device-tier — flatten every Skill-Universe motion + effect from the single source (§C). */
+:root[data-device-tier="low"] .su-pulse {
+  animation: none;
+  opacity: 0;
+}
+:root[data-device-tier="low"] .su-center-ring::after {
+  animation: none;
+}
+:root[data-device-tier="low"] .su-node:hover .su-node-badge,
+:root[data-device-tier="low"] .su-node-on .su-node-badge {
+  transform: translate(0, 0);
+}
+:root[data-device-tier="low"] .su-reveal-card {
+  animation: none;
+}
