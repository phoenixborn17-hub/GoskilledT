+          <p className="text-xs font-medium uppercase tracking-wide text-muted">
+            Lifetime
+          </p>
+          <p className="font-heading text-xl font-bold text-charcoal">
+            {formatINR(detail.summary.lifetimeEarnedInPaise)}
+          </p>
+        </Card>
+      </div>
